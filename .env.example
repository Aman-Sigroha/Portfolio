# ── Server ───────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Database ─────────────────────────────────────
# PostgreSQL connection string
# Local:      postgresql://postgres:password@localhost:5432/portfolio
# Neon:       postgresql://...@neon.tech/...
DATABASE_URL=postgresql://postgres:password@localhost:5432/portfolio

# ── Client ───────────────────────────────────────
# Comma-separated allowed frontend origins
# Local:      http://localhost:5173
# Production: https://your-site.vercel.app
CLIENT_ORIGIN=http://localhost:5173

# ── Email (optional — for contact form notifications) ─
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=amansigrohawork@gmail.com
SMTP_PASS=your_app_password
NOTIFY_EMAIL=amansigrohawork@gmail.com
